{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://osi.example/schema/behavior-layer/0.1",
  "title": "OSI Behavior Layer Extension",
  "type": "object",
  "additionalProperties": true,
  "required": ["namespace", "behavior_layer_version", "action_types", "rules"],
  "properties": {
    "namespace": { "type": "string", "minLength": 1 },
    "behavior_layer_version": { "type": "string", "minLength": 1 },
    "metadata": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "owner": { "type": "string" },
        "last_updated": { "type": "string" },
        "tags": { "type": "array", "items": { "type": "string" } }
      }
    },
    "action_types": {
      "type": "array",
      "items": { "$ref": "#/$defs/actionType" }
    },
    "rules": {
      "type": "array",
      "items": { "$ref": "#/$defs/rule" }
    }
  },
  "$defs": {
    "actionType": {
      "type": "object",
      "additionalProperties": true,
      "required": ["id", "title"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "title": { "type": "string", "minLength": 1 },
        "description": { "type": "string" },
        "kind": { "type": "string", "enum": ["command", "query"] },
        "operation": {
          "type": "string",
          "anyOf": [
            {
              "enum": [
                "create",
                "read",
                "update",
                "delete",
                "list",
                "search",
                "upsert",
                "batch_create",
                "batch_update",
                "batch_delete"
              ]
            },
            {
              "pattern": "^[a-z][a-z0-9_]*$"
            }
          ]
        },
        "aggregate": { "type": "string" },
        "entity_name": { "type": "string" },
        "idempotency": { "type": "string", "enum": ["idempotent", "non_idempotent", "unknown"] },
        "applies_to": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "entity": { "type": "string", "enum": ["dataset", "field", "metric", "relationship"] },
            "selectors": {
              "type": "object",
              "additionalProperties": true,
              "properties": {
                "field_names": { "type": "array", "items": { "type": "string" } },
                "metric_names": { "type": "array", "items": { "type": "string" } },
                "relationship_names": { "type": "array", "items": { "type": "string" } }
              }
            }
          }
        },
        "io_schema": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "input_schema": { "type": "object" },
            "output_schema": { "type": "object" }
          }
        },
        "examples": { "type": "array", "items": { "type": "string" } },
        "tool_hint": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "tool_name": { "type": "string" },
            "dialect": { "type": "string", "enum": ["ANSI_SQL", "SNOWFLAKE", "DATABRICKS", "MDX", "TABLEAU"] }
          }
        },
        "tags": { "type": "array", "items": { "type": "string" } },
        "synonyms": { "type": "array", "items": { "type": "string" } },
        "deprecated": { "type": "boolean" },
        "version": { "type": "string" }
      }
    },
    "rule": {
      "type": "object",
      "additionalProperties": true,
      "required": ["id", "title", "severity", "when", "constraint", "message"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "title": { "type": "string", "minLength": 1 },
        "description": { "type": "string" },
        "severity": { "type": "string", "enum": ["error", "warn", "info"] },
        "when": {
          "type": "object",
          "additionalProperties": true,
          "required": ["entity"],
          "properties": {
            "entity": { "type": "string", "enum": ["dataset", "field", "metric", "relationship"] },
            "selectors": {
              "type": "object",
              "additionalProperties": true,
              "properties": {
                "field_names": { "type": "array", "items": { "type": "string" } },
                "metric_names": { "type": "array", "items": { "type": "string" } },
                "relationship_names": { "type": "array", "items": { "type": "string" } }
              }
            }
          }
        },
        "if": { "type": "object", "additionalProperties": true },
        "constraint": {
          "type": "object",
          "additionalProperties": true,
          "required": ["type"],
          "properties": {
            "type": {
              "type": "string",
              "enum": [
                "naming",
                "expression",
                "join",
                "filter",
                "security",
                "quality",
                "definition",
                "compliance",
                "consistency",
                "reconciliation",
                "relationship_integrity",
                "state_machine",
                "diagnostic",
                "other"
              ]
            },
            "pattern": { "type": "string" },
            "required": { "type": "array", "items": { "type": "string" } },
            "forbidden": { "type": "array", "items": { "type": "string" } },
            "max_length": { "type": "number" },
            "min_length": { "type": "number" }
          }
        },
        "message": { "type": "string", "minLength": 1 },
        "remediation": { "type": "string" },
        "references": { "type": "array", "items": { "type": "object", "additionalProperties": true } },
        "tags": { "type": "array", "items": { "type": "string" } }
      }
    }
  }
}
